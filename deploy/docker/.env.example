# SPDX-License-Identifier: Apache-2.0
# Copy this file to `.env` and edit. `.env` is gitignored.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
AGI_ENV=dev                  # dev | production
AGI_AUTH=dev-noop            # dev-noop | static | keycloak  (NEVER dev-noop in prod)
AGI_LLM_PROVIDER=fake        # fake | bedrock | ollama | openai | anthropic

# ---------------------------------------------------------------------------
# OIDC (only required when AGI_AUTH=keycloak)
# ---------------------------------------------------------------------------
AGI_OIDC_ISSUER=             # e.g. http://localhost:8081/realms/agi
AGI_OIDC_AUDIENCE=agi-runtime
AGI_OIDC_TENANT_CLAIM=tenant_id

# ---------------------------------------------------------------------------
# Static-token (only required when AGI_AUTH=static)
# ---------------------------------------------------------------------------
AGI_STATIC_TOKEN=
AGI_STATIC_TENANT=
AGI_STATIC_SUB=static-user
AGI_STATIC_SCOPES=AGI_VIEWER

# ---------------------------------------------------------------------------
# Langfuse (the dev compose generates these, but you should rotate for prod)
# ---------------------------------------------------------------------------
LANGFUSE_NEXTAUTH_SECRET=change-me-please
LANGFUSE_SALT=change-me-please

# ---------------------------------------------------------------------------
# LLM provider secrets — wire via your secret manager in real deployments
# ---------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_HOST=http://host.docker.internal:11434
