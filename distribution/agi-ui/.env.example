# SPDX-License-Identifier: Apache-2.0
# Auth.js v5 + Keycloak — copy to `.env.local` and fill in.

# OIDC issuer URL (Keycloak realm).
AGI_OIDC_ISSUER=http://localhost:8081/realms/agi

# OIDC client created in Keycloak for the admin console.
AGI_OIDC_CLIENT_ID=agi-ui
AGI_OIDC_CLIENT_SECRET=changeme

# Auth.js v5 cookie-signing / JWT-encryption secret. Generate with:
#   openssl rand -base64 32
# Equivalent names AUTH_SECRET / NEXTAUTH_SECRET are both accepted by v5.
NEXTAUTH_SECRET=changeme
AUTH_SECRET=changeme

# Public-facing URL of the console — used to build OAuth callback URLs.
NEXTAUTH_URL=http://localhost:8080

# Backend runtime — read by the same-origin BFF at /api/runtime/* (Agent 4a-C).
AGI_RUNTIME_URL=http://localhost:9000
